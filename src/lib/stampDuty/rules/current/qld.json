  "base_duty_rules": [
    {
      "id": "qld_home_concession_rates_2024_06_09",
      "effective_from": "2024-06-09",
      "effective_to": null,
      "priority": 10,
      "applies_if": {
        "operator": "AND",
        "conditions": [
          { "field": "owner_occupier", "op": "eq", "value": true },
          {
            "field": "property_type",
            "op": "in",
