    { "key": "first_home_buyer", "type": "boolean", "required": true },
    { "key": "owner_occupier", "type": "boolean", "required": true },
    { "key": "foreign_buyer", "type": "boolean", "required": false },
    {
      "key": "state_specific_inputs",
      "type": "array",
      "required": false,
      "description": "Reserved for future QLD-specific parameters."
    }
  ],
