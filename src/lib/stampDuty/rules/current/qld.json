      "id": "qld_first_home_home_concession_2024_06_09",
      "name": "Queensland first home concession (home)",
      "effective_from": "2024-06-09",
      "effective_to": null,
      "priority": 10,
      "eligibility": {
        "operator": "AND",
        "conditions": [
          { "field": "first_home_buyer", "op": "eq", "value": true },
          { "field": "owner_occupier", "op": "eq", "value": true },
