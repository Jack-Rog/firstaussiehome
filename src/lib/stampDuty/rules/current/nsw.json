  "concessions": [
    {
      "id": "nsw_fhbas_broad_model_2026_03_03",
      "name": "NSW first-home broad relief model",
      "effective_from": "2026-03-03",
      "effective_to": null,
      "priority": 10,
      "eligibility": {
        "operator": "AND",
        "conditions": [
          { "field": "first_home_buyer", "op": "eq", "value": true },
          { "field": "owner_occupier", "op": "eq", "value": true },
          {
            "field": "property_type",
            "op": "in",
            "value": [
              "established_home",
              "new_home",
              "off_the_plan_apartment",
              "house_and_land_package"
            ]
          }
        ]
      },
      "effect_type": "replace_with_piecewise_formula",
      "piecewise_effect_brackets": [
        {
          "min_value": 0,
          "max_value": 800000,
          "effect_formula_type": "zero"
        },
        {
          "min_value": 800000.01,
          "max_value": 999999.99,
