  "surcharges": [
    {
      "id": "sa_foreign_ownership_surcharge_2018_01_01",
      "name": "South Australia foreign ownership surcharge",
      "effective_from": "2018-01-01",
      "effective_to": null,
      "eligibility": {
        "operator": "AND",
        "conditions": [
          { "field": "foreign_buyer", "op": "eq", "value": true },
          {
            "field": "property_type",
            "op": "in",
            "value": [
              "established_home",
              "new_home",
              "vacant_land",
              "off_the_plan_apartment",
              "house_and_land_package"
            ]
          }
        ]
      },
      "calculation_method": "percent_of_value",
      "percent": 7,
      "fallback_url": "https://revenuesa.sa.gov.au/stamp-duty/foreign-ownership-surcharge",
      "source_refs": ["sa-foreign-ownership-surcharge"],
      "notes": [
        "RevenueSA states the surcharge of 7% applies to the value of the interest acquired in residential land from 1 January 2018."
      ]
