  "concessions": [
    {
      "id": "sa_first_home_new_home_full_relief_2023_06_15",
      "name": "SA first-home full relief for new homes (value-capped period)",
      "effective_from": "2023-06-15",
      "effective_to": "2024-06-05",
      "priority": 10,
      "eligibility": {
        "operator": "AND",
        "conditions": [
          { "field": "first_home_buyer", "op": "eq", "value": true },
          { "field": "owner_occupier", "op": "eq", "value": true },
          {
            "field": "property_type",
            "op": "in",
            "value": ["new_home", "off_the_plan_apartment", "house_and_land_package"]
          },
          { "field": "property_value", "op": "lte", "value": 650000 }
        ]
      },
      "effect_type": "set_duty_to_zero",
      "source_refs": ["sa-first-home"]
    },
    {
      "id": "sa_first_home_new_home_partial_relief_2023_06_15",
      "name": "SA first-home partial relief for new homes",
      "effective_from": "2023-06-15",
      "effective_to": "2024-06-05",
      "priority": 20,
      "eligibility": {
        "operator": "AND",
        "conditions": [
          { "field": "first_home_buyer", "op": "eq", "value": true },
          { "field": "owner_occupier", "op": "eq", "value": true },
          {
            "field": "property_type",
            "op": "in",
            "value": ["new_home", "off_the_plan_apartment", "house_and_land_package"]
          },
          { "field": "property_value", "op": "between", "min": 650000.01, "max": 700000 }
        ]
      },
      "effect_type": "replace_with_piecewise_formula",
      "piecewise_effect_brackets": [
        {
          "min_value": 650000.01,
          "max_value": 700000,
          "effect_formula_type": "formula_expression",
          "expression": "Math.max(0, Math.min(currentDuty, currentDuty * ((value - 650000) / 50000)))"
        }
      ],
      "source_refs": ["sa-first-home"],
      "notes": [
        "RevenueSA partial-relief formula applied: duty payable = duty * ((dutiable value - 650,000) / 50,000)."
      ]
    },
    {
