      "last_verified": "2026-03-10"
    }
  ],
  "base_duty_rules": [
    {
      "id": "nt_general_2017_07_01",
      "effective_from": "2017-07-01",
      "effective_to": null,
      "priority": 10,
      "calculation_method": "formula_piecewise",
      "rounding": "floor_to_5_cents",
      "formula_segments": [
        {
          "min_value": 0,
          "max_value": 525000,
          "expression": "(0.06571441 * Math.pow(value / 1000, 2)) + (15 * (value / 1000))"
        },
        {
          "min_value": 525000.01,
          "max_value": 2999999.99,
          "expression": "0.0495 * value"
        },
        {
          "min_value": 3000000,
          "max_value": 4999999.99,
          "expression": "0.0575 * value"
        },
        {
          "min_value": 5000000,
          "max_value": null,
          "expression": "0.0595 * value"
        }
      ],
      "source_refs": ["nt-calculators-js", "nt-conveyance-calculator"]
    },
