  "concessions": [
    {
      "id": "nt_first_home_house_and_land_exemption_2022_07_01",
      "name": "NT first-home house and land package duty exemption",
      "effective_from": "2022-07-01",
      "effective_to": "2027-06-30",
      "priority": 10,
      "eligibility": {
        "operator": "AND",
        "conditions": [
          { "field": "first_home_buyer", "op": "eq", "value": true },
          { "field": "owner_occupier", "op": "eq", "value": true },
          { "field": "property_type", "op": "eq", "value": "house_and_land_package" }
        ]
      },
      "effect_type": "set_duty_to_zero",
      "source_refs": ["nt-conveyance-calculator", "nt-stamp-duty"],
      "notes": [
        "NT HomeGrown Territory provides a full stamp duty exemption for eligible first-home house and land packages signed from 1 July 2022 to 30 June 2027.",
        "No broad NT first-home concession is applied to established homes in this ruleset."
      ]
    }
  ],
  "surcharges": [
    {
      "id": "nt_foreign_buyer_surcharge_hook_2026_03_10",
      "name": "NT foreign buyer surcharge hook",
      "effective_from": "2026-03-10",
      "effective_to": null,
      "eligibility": {
        "operator": "AND",
        "conditions": [{ "field": "foreign_buyer", "op": "eq", "value": true }]
      },
      "calculation_method": "unresolved",
      "fallback_url": "https://nt.gov.au/employ/money-and-taxes/taxes-royalties-and-grants/stamp-duty",
      "source_refs": ["nt-stamp-duty"],
      "notes": [
        "No confirmed NT foreign purchaser surcharge formula is currently encoded.",
        "Retained as a hook for future legislative extraction."
      ]
    }
  ],
  "notes": [
    "NT base duty formulas and date cutovers are encoded from the official NT calculator script.",
    "NT applies floor-to-nearest-5-cents rounding for conveyance calculations, matching official calculator behaviour.",
    "NT first-home house-and-land exemption is encoded for the 1 July 2022 to 30 June 2027 period.",
