  "concessions": [
    {
      "id": "tas_first_home_established_discount_50_2018_02_07",
      "name": "Tasmania first-home established home duty relief (50%)",
      "effective_from": "2018-02-07",
      "effective_to": "2024-02-17",
      "priority": 10,
      "eligibility": {
        "operator": "AND",
        "conditions": [
          { "field": "first_home_buyer", "op": "eq", "value": true },
          { "field": "owner_occupier", "op": "eq", "value": true },
          { "field": "property_type", "op": "eq", "value": "established_home" },
          { "field": "property_value", "op": "lte", "value": 750000 }
        ]
      },
      "effect_type": "apply_percent_discount",
      "discount_percent": 50,
      "source_refs": ["tas-first-home-established"]
    },
    {
      "id": "tas_first_home_established_exemption_2024_02_18",
      "name": "Tasmania first-home established home duty relief (100%)",
      "effective_from": "2024-02-18",
      "effective_to": "2026-06-30",
      "priority": 10,
      "eligibility": {
        "operator": "AND",
        "conditions": [
          { "field": "first_home_buyer", "op": "eq", "value": true },
          { "field": "owner_occupier", "op": "eq", "value": true },
          { "field": "property_type", "op": "eq", "value": "established_home" },
          { "field": "property_value", "op": "lte", "value": 750000 }
        ]
      },
      "effect_type": "set_duty_to_zero",
      "source_refs": ["tas-first-home-established"]
    },
    {
      "id": "tas_first_home_established_post_2026_unresolved",
      "name": "Tasmania first-home established home duty relief (post-30 June 2026 unresolved)",
      "effective_from": "2026-07-01",
      "effective_to": null,
      "priority": 10,
      "eligibility": {
        "operator": "AND",
        "conditions": [
          { "field": "first_home_buyer", "op": "eq", "value": true },
          { "field": "owner_occupier", "op": "eq", "value": true },
          { "field": "property_type", "op": "eq", "value": "established_home" },
          { "field": "property_value", "op": "lte", "value": 750000 }
        ]
      },
      "effect_type": "replace_with_alternate_base_rule",
      "source_refs": ["tas-first-home-established"],
      "notes": [
        "SRO Tasmania duty-relief settings after 30 June 2026 are not yet encoded."
      ]
    }
  ],
  "surcharges": [
    {
      "id": "tas_fids_2022_07_01",
      "name": "Tasmania foreign investor duty surcharge",
      "effective_from": "2022-07-01",
      "effective_to": null,
      "eligibility": {
        "operator": "AND",
        "conditions": [
          { "field": "foreign_buyer", "op": "eq", "value": true },
          {
            "field": "property_type",
            "op": "in",
            "value": [
              "established_home",
              "new_home",
              "vacant_land",
              "off_the_plan_apartment",
              "house_and_land_package"
            ]
          }
        ]
      },
      "calculation_method": "percent_of_value",
      "percent": 8,
      "fallback_url": "https://www.sro.tas.gov.au/property-transfer-duties/foreign-investor-duty-surcharge",
      "source_refs": ["tas-fids"],
      "notes": ["FIDS rate increased to 8% from 1 July 2022."]
    },
    {
      "id": "tas_fids_2018_07_01",
      "name": "Tasmania foreign investor duty surcharge",
      "effective_from": "2018-07-01",
      "effective_to": "2022-06-30",
      "eligibility": {
        "operator": "AND",
        "conditions": [
          { "field": "foreign_buyer", "op": "eq", "value": true },
          {
            "field": "property_type",
            "op": "in",
            "value": [
              "established_home",
              "new_home",
              "vacant_land",
              "off_the_plan_apartment",
              "house_and_land_package"
            ]
          }
        ]
      },
      "calculation_method": "percent_of_value",
      "percent": 3,
      "fallback_url": "https://www.sro.tas.gov.au/property-transfer-duties/foreign-investor-duty-surcharge",
      "source_refs": ["tas-fids"],
      "notes": ["FIDS rate was 3% from 1 July 2018 to 30 June 2022."]
    }
  ],
  "notes": [
    "TAS base duty and FIDS schedules are encoded from SRO Tasmania tables.",
    "First-home established-home relief is date-versioned at 50% then 100%, with post-30 June 2026 left unresolved pending legislative updates."
  ]
}
