{
  "jurisdiction": "TAS",
  "ruleset_version": "2026-03-10.tas.v2",
  "currency": "AUD",
  "inputs": [
    { "key": "transaction_date", "type": "date", "required": true },
    { "key": "property_value", "type": "number", "required": true },
    {
      "key": "property_type",
      "type": "enum",
      "required": true,
      "enum_values": [
        "established_home",
        "new_home",
        "vacant_land",
        "off_the_plan_apartment",
        "house_and_land_package",
        "other"
      ]
    },
    { "key": "first_home_buyer", "type": "boolean", "required": true },
    { "key": "owner_occupier", "type": "boolean", "required": true },
    { "key": "foreign_buyer", "type": "boolean", "required": false },
    {
      "key": "state_specific_inputs",
      "type": "array",
      "required": false,
      "description": "Reserved for future TAS-specific parameters."
    }
  ],
  "official_sources": [
    {
      "id": "tas-rates-of-duty",
      "label": "State Revenue Office Tasmania rates of property transfer duty",
