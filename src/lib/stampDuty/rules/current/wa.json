{
  "jurisdiction": "WA",
  "ruleset_version": "2026-03-10.wa.v2",
  "currency": "AUD",
  "inputs": [
    { "key": "transaction_date", "type": "date", "required": true },
    { "key": "property_value", "type": "number", "required": true },
    {
      "key": "property_type",
      "type": "enum",
      "required": true,
      "enum_values": [
        "established_home",
        "new_home",
        "vacant_land",
        "off_the_plan_apartment",
        "house_and_land_package",
        "other"
      ]
    },
    { "key": "first_home_buyer", "type": "boolean", "required": true },
    { "key": "owner_occupier", "type": "boolean", "required": true },
    { "key": "foreign_buyer", "type": "boolean", "required": false },
    {
      "key": "state_specific_inputs",
      "type": "array",
      "required": false,
      "description": "Optional WA keys: state_specific_inputs.wa_region = metro_or_peel | regional."
    }
  ],
  "official_sources": [
    {
      "id": "wa-transfer-duty",
      "label": "WA transfer duty rates",
      "url": "https://www.wa.gov.au/service/financial-management/taxation-and-duty-payments/transfer-duty",
      "last_verified": "2026-03-10"
    },
    {
      "id": "wa-first-home-owner-rate",
      "label": "WA duties fact sheet - first home owner rate",
      "url": "https://www.wa.gov.au/government/publications/duties-fact-sheet-first-home-owner-rate",
      "last_verified": "2026-03-10"
    },
    {
      "id": "wa-foreign-transfer-duty",
      "label": "WA foreign transfer duty",
      "url": "https://www.wa.gov.au/government/publications/foreign-transfer-duty",
      "last_verified": "2026-03-10"
    }
  ],
  "base_duty_rules": [
    {
      "id": "wa_first_home_home_region_required_unresolved_2025_03_21",
      "effective_from": "2025-03-21",
      "effective_to": null,
      "priority": 5,
      "applies_if": {
        "operator": "AND",
        "conditions": [
          { "field": "first_home_buyer", "op": "eq", "value": true },
          { "field": "owner_occupier", "op": "eq", "value": true },
          {
            "field": "property_type",
            "op": "in",
            "value": [
              "established_home",
              "new_home",
              "off_the_plan_apartment",
              "house_and_land_package"
            ]
          },
          { "field": "property_value", "op": "between", "min": 500000.01, "max": 750000 },
          {
            "field": "state_specific_inputs.wa_region",
            "op": "not_in",
            "value": ["metro_or_peel", "regional"]
          }
        ]
      },
      "calculation_method": "unresolved",
      "fallback_url": "https://www.wa.gov.au/government/publications/duties-fact-sheet-first-home-owner-rate",
      "source_refs": ["wa-first-home-owner-rate"],
      "unresolved_reason": "WA first-home rates differ for metro/Peel and regional values above 500,000.",
      "todo": "Pass state_specific_inputs.wa_region as metro_or_peel or regional."
    },
