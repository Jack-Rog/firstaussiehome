{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://firstaussiehome.com/schemas/stamp-duty-rules.schema.json",
  "title": "Australian Stamp Duty Jurisdiction Ruleset",
  "description": "Versioned ruleset for Australian stamp duty base rates, concessions, surcharges, and calculator fallbacks.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "jurisdiction",
    "ruleset_version",
    "currency",
    "inputs",
    "base_duty_rules",
    "concessions",
    "official_sources"
  ],
  "properties": {
    "jurisdiction": {
      "type": "string",
      "enum": ["NSW", "VIC", "QLD", "WA", "SA", "TAS", "ACT", "NT"]
    },
    "ruleset_version": { "type": "string" },
    "currency": { "type": "string", "enum": ["AUD"] },
    "inputs": {
      "type": "array",
      "items": { "$ref": "#/$defs/inputDefinition" }
    },
    "base_duty_rules": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/baseDutyRule" }
    },
    "concessions": {
      "type": "array",
      "items": { "$ref": "#/$defs/concessionRule" }
    },
    "surcharges": {
      "type": "array",
      "items": { "$ref": "#/$defs/surchargeRule" }
    },
    "official_sources": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/source" }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "inputDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "type"],
      "properties": {
        "key": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["string", "number", "integer", "boolean", "date", "enum", "array"]
        },
        "required": { "type": "boolean", "default": false },
        "enum_values": {
          "type": "array",
          "items": { "type": "string" }
        },
        "description": { "type": "string" }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "url"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "last_verified": { "type": "string", "format": "date" },
        "notes": { "type": "string" }
      }
    },
    "condition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field", "op"],
      "properties": {
        "field": { "type": "string" },
        "op": {
          "type": "string",
          "enum": [
            "eq",
            "neq",
            "lt",
            "lte",
            "gt",
            "gte",
            "in",
            "not_in",
            "between",
            "date_gte",
            "date_lte",
            "exists",
            "contains"
          ]
        },
        "value": {},
        "min": { "type": ["number", "string"] },
        "max": { "type": ["number", "string"] }
      }
    },
    "conditionGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operator", "conditions"],
      "properties": {
        "operator": { "type": "string", "enum": ["AND", "OR"] },
        "conditions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "oneOf": [{ "$ref": "#/$defs/condition" }, { "$ref": "#/$defs/conditionGroup" }]
          }
        }
      }
    },
    "bracket": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min_value", "max_value", "formula_type"],
      "properties": {
        "min_value": { "type": "number" },
        "max_value": { "type": ["number", "null"] },
        "formula_type": {
          "type": "string",
          "enum": ["marginal", "flat_rate_on_total", "fixed_plus_marginal"]
        },
        "fixed_amount": { "type": "number", "default": 0 },
        "rate_per_100": { "type": ["number", "null"] },
        "percent_of_total": { "type": ["number", "null"] },
        "marginal_base_value": { "type": ["number", "null"] }
      }
    },
    "formulaSegment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min_value", "max_value", "expression"],
      "properties": {
        "min_value": { "type": "number" },
        "max_value": { "type": ["number", "null"] },
        "expression": { "type": "string" },
        "variables": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "lookupPoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "duty"],
      "properties": {
        "value": { "type": "number" },
        "duty": { "type": "number" }
      }
    },
    "baseDutyRule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "effective_from", "calculation_method"],
      "properties": {
        "id": { "type": "string" },
        "effective_from": { "type": "string", "format": "date" },
        "effective_to": { "type": ["string", "null"], "format": "date" },
        "priority": { "type": "integer", "default": 100 },
        "applies_if": { "$ref": "#/$defs/conditionGroup" },
        "calculation_method": {
          "type": "string",
          "enum": [
            "brackets",
            "flat_percent",
            "formula_piecewise",
            "lookup_table",
            "official_calculator_fallback",
            "unresolved"
          ]
        },
        "rounding": {
          "type": "string",
          "enum": [
            "none",
            "ceil_to_dollar",
            "ceil_each_$100_part",
            "jurisdiction_specific",
            "floor_to_5_cents"
          ]
        },
        "brackets": {
          "type": "array",
          "items": { "$ref": "#/$defs/bracket" }
        },
        "flat_percent": { "type": "number" },
        "formula_segments": {
          "type": "array",
          "items": { "$ref": "#/$defs/formulaSegment" }
        },
        "lookup_table": {
          "type": "array",
          "items": { "$ref": "#/$defs/lookupPoint" }
        },
        "fallback_url": { "type": "string", "format": "uri" },
        "source_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "unresolved_reason": { "type": "string" },
        "todo": { "type": "string" }
      }
    },
    "effectBracket": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min_value", "max_value", "effect_formula_type"],
      "properties": {
        "min_value": { "type": "number" },
        "max_value": { "type": ["number", "null"] },
        "effect_formula_type": {
          "type": "string",
          "enum": [
            "zero",
            "fixed_plus_marginal",
            "flat_rate_on_total",
            "subtract_fixed_amount",
            "lookup_table",
            "formula_expression",
            "informational_only"
          ]
        },
        "fixed_amount": { "type": ["number", "null"] },
        "rate_per_100": { "type": ["number", "null"] },
        "percent_of_total": { "type": ["number", "null"] },
        "marginal_base_value": { "type": ["number", "null"] },
        "subtract_amount": { "type": ["number", "null"] },
        "expression": { "type": "string" },
        "lookup_table": {
          "type": "array",
          "items": { "$ref": "#/$defs/lookupPoint" }
        }
      }
    },
    "concessionRule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "effective_from", "effect_type", "eligibility"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "effective_from": { "type": "string", "format": "date" },
        "effective_to": { "type": ["string", "null"], "format": "date" },
        "eligibility": { "$ref": "#/$defs/conditionGroup" },
        "effect_type": {
          "type": "string",
          "enum": [
            "set_duty_to_zero",
            "replace_with_alternate_base_rule",
            "subtract_fixed_amount",
            "replace_with_piecewise_formula",
            "apply_percent_discount",
            "informational_only"
          ]
        },
        "priority": { "type": "integer", "default": 100 },
        "alternate_base_rule_id": { "type": ["string", "null"] },
        "piecewise_effect_brackets": {
          "type": "array",
          "items": { "$ref": "#/$defs/effectBracket" }
        },
        "discount_percent": { "type": ["number", "null"] },
        "fixed_reduction_amount": { "type": ["number", "null"] },
        "source_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "surchargeRule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "effective_from", "eligibility", "calculation_method"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "effective_from": { "type": "string", "format": "date" },
        "effective_to": { "type": ["string", "null"], "format": "date" },
        "eligibility": { "$ref": "#/$defs/conditionGroup" },
        "calculation_method": {
          "type": "string",
          "enum": ["percent_of_value", "percent_of_base_duty", "fixed_amount", "unresolved"]
        },
        "percent": { "type": ["number", "null"] },
        "fixed_amount": { "type": ["number", "null"] },
        "fallback_url": { "type": "string", "format": "uri" },
        "source_refs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
