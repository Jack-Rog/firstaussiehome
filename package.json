{
  "name": "aussies-first-home",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "setup:local": "npm run prisma:generate && playwright install chromium",
    "build": "next build",
    "start": "next start",
    "validate:stamp-duty-rules": "node scripts/validate-stamp-duty-rules.mjs",
    "lint": "npm run validate:stamp-duty-rules && npm run compliance:check && eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run test:e2e && npm run build",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "compliance:check": "node scripts/compliance-lint.mjs"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@prisma/client": "^6.16.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.542.0",
    "next": "16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "next-mdx-remote": "^6.0.0",
    "nodemailer": "^7.0.13",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "remark-gfm": "^4.0.1",
    "resend": "^6.0.1",
    "stripe": "^20.4.0",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^6.16.3",
    "tailwindcss": "^4",
    "tsx": "^4.20.5",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
